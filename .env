# Public build-time config, committed on purpose.
#
# These VITE_ variables are inlined into the client bundle at build time and
# are therefore already public — they are safe to commit. Committing them means
# every local build (and manual `wrangler pages deploy`) picks up the correct
# Supabase project instead of silently falling back to defaults.
#
# NEVER put secrets here (service-role key, JWT secret, etc.). Anything secret
# or environment-specific goes in .env.local, which is gitignored.

VITE_SUPABASE_URL=https://frncdqehmtfbteyrnymp.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ysbdMQ642XC5xHqVWFmezg_Y0mXbUI3
